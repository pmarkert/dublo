# AWS credentials can also come from your default profile or IAM role
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Optional global defaults (<workspace>/config.json overrides these)
DUBLO_WORKSPACE=./.dublo
DUBLO_BASE_URL=http://localhost:8080
DUBLO_MAX_STEPS=40
DUBLO_HEADLESS=false
DUBLO_OUTPUT_DIR=./output/runs

# Optional selectors (path or profile name)
# DUBLO_LLM=default
# DUBLO_PERSONA=qa-strict
# DUBLO_SCENARIO=checkout-happy-path
# DUBLO_CONTEXT=shared,qa-user

# LLM defaults
DUBLO_LLM_PROVIDER=bedrock
DUBLO_LLM_REGION=us-east-1
DUBLO_LLM_MODEL_ID=amazon.nova-pro-v1:0
# Optional direct LLM price overrides in USD per 1M tokens
# DUBLO_LLM_INPUT_PRICE=0.8
# DUBLO_LLM_OUTPUT_PRICE=3.2
# DUBLO_LLM_CACHE_READ_PRICE=0.2
# DUBLO_LLM_CACHE_WRITE_PRICE=0
# DUBLO_LLM_CURRENCY=USD
# DUBLO_LLM_TOKEN_UNIT=1000000

# OpenAI-compatible local LLM (set DUBLO_LLM_PROVIDER=openai-compatible to use)
# DUBLO_LLM_BASE_URL=http://localhost:11434/v1
# DUBLO_LLM_API_KEY=
